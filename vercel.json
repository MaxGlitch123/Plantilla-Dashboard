{
  "rewrites": [
    { 
      "source": "/api-proxy/:path*", 
      "destination": "https://back-buensabor-a0wy.onrender.com/api/:path*"
    },
    {
      "source": "/ws", 
      "destination": "wss://back-buensabor-a0wy.onrender.com/api/ws"
    },
    { 
      "source": "/(.*)", 
      "destination": "/" 
    }
  ],
  "headers": [
    {
      "source": "/api-proxy/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization, X-User-Role" }
      ]
    }
  ]
}